# Copy to .env and fill in. Nothing here is required to run locally —
# the app works out of the box with SQLite and unauthenticated Reddit search.

ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:5173

DATABASE_URL=sqlite:///./sentiment.db

# --- Reddit (optional but recommended: https://www.reddit.com/prefs/apps) ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=p51-sentiment-platform/0.1 by yourusername

# --- Sentiment model ---
SENTIMENT_MODEL_NAME=distilbert-base-uncased-finetuned-sst-2-english

# --- Azure AI Language (optional upgrade) ---
USE_AZURE_AI_LANGUAGE=false
AZURE_LANGUAGE_ENDPOINT=
AZURE_LANGUAGE_KEY=

# --- Azure Cosmos DB (optional, for production deployment) ---
USE_COSMOS=false
COSMOS_CONNECTION_STRING=
COSMOS_DATABASE_NAME=sentiment_platform
COSMOS_CONTAINER_NAME=posts

# --- Alerts ---
NEGATIVE_SPIKE_THRESHOLD=0.4
ALERT_WINDOW_MINUTES=15

# --- Scheduler ---
FETCH_INTERVAL_SECONDS=300
